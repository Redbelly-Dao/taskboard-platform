rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the calling user's role
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // True if the caller may read/act on a submission for this taskId: admins
    // always can; reviewers can unless they've submitted to this task
    // themselves (conflict of interest). Exactly ONE users/{uid} lookup via
    // `let` — this runs once per matched document in the reviewer queue's
    // list query, and Firestore caps rule evaluation at 10 document accesses
    // per request, so a second get() here would double that cost per
    // document and silently break the queue once it holds more than ~5
    // submissions (which is exactly what happened: role() alone already
    // spent one get() per doc, adding a second get() here tipped 5 docs over
    // the 10-access ceiling).
    function reviewerOrAdminMayAccessSubmission(taskId) {
      let caller = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return caller.role == "admin" || (caller.role == "reviewer" && !(taskId in caller.get("submittedTaskIds", [])));
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || role() == "admin"
      );
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == "contributor";
      allow update: if request.auth != null && (
        role() == "admin" ||
        (request.auth.uid == userId && !("role" in request.resource.data.diff(resource.data).affectedKeys()))
      );
    }

    // Pending role pre-grants (admin "add user"). Applied server-side on wallet
    // register/login via the Admin SDK, which bypasses these rules; client access
    // is admin-only.
    match /pendingGrants/{wallet} {
      allow read, create, update, delete: if request.auth != null && role() == "admin";
    }

    // Feedback — any authenticated user may submit; only admins can read/manage.
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && role() == "admin";
    }

    // Tasks collection — publicly readable; write restricted to admins, EXCEPT that
    // any authenticated user may bump `submissionCount` by exactly 1 (done atomically
    // when they create a submission) so the public per-task cap is visible + enforceable.
    match /tasks/{taskId} {
      allow read: if true;
      allow create, delete: if request.auth != null && role() == "admin";
      allow update: if request.auth != null && (
        role() == "admin" ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["submissionCount"]) &&
          request.resource.data.submissionCount is int &&
          request.resource.data.submissionCount >= 0 &&
          (
            // reviewers recount active (non-rejected) submissions authoritatively
            role() == "reviewer" ||
            // contributors may only bump by 1 (atomic with creating a submission)
            request.resource.data.submissionCount == resource.data.get("submissionCount", 0) + 1
          )
        ) ||
        (
          // Claim Task / Start Work: a contributor may flip status through these
          // two exact steps only, nothing else on the doc, no other transition.
          role() == "contributor" &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"]) &&
          (
            (resource.data.status == "open" && request.resource.data.status == "assigned") ||
            (resource.data.status == "assigned" && request.resource.data.status == "in_progress")
          )
        )
      );
    }

    // Submissions collection
    match /submissions/{submissionId} {
      // Contributors and reviewers may submit; admins never do (they have no
      // contributor rights). A task that is completed or paused accepts no
      // new submissions, enforced here, not just hidden in the UI.
      allow create: if request.auth != null
        && request.resource.data.contributorId == request.auth.uid
        && request.resource.data.status == "under_review"
        && role() != "admin"
        && !(get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.status in ["completed", "paused"]);
      allow read: if request.auth != null && (
        resource.data.contributorId == request.auth.uid ||
        reviewerOrAdminMayAccessSubmission(resource.data.taskId)
      );
      allow update: if request.auth != null && (
        reviewerOrAdminMayAccessSubmission(resource.data.taskId) ||
        (
          resource.data.contributorId == request.auth.uid &&
          resource.data.status == "revision_requested" &&
          request.resource.data.status == "under_review"
        )
      );

      // Submission chat messages, same conflict-of-interest rule: a reviewer
      // can't read or post in the chat for a task they submitted to either.
      // messageMayAccess() fetches the parent submission exactly once and
      // reuses it for both the ownership check and the taskId conflict check
      // (this rule runs per message in a chat thread's list query, so a
      // second/third redundant get() here would multiply the same way the
      // reviewer queue bug did).
      function messageMayAccess() {
        let sub = get(/databases/$(database)/documents/submissions/$(submissionId)).data;
        return sub.contributorId == request.auth.uid || reviewerOrAdminMayAccessSubmission(sub.taskId);
      }
      match /messages/{messageId} {
        allow read: if request.auth != null && messageMayAccess();
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && messageMayAccess();
      }
    }

    // Notifications
    match /notifications/{notifId} {
      // Read own personal notifications, or admins read broadcast notifications
      allow read: if request.auth != null && (
        resource.data.recipientId == request.auth.uid ||
        (resource.data.forAdmins == true && role() == "admin")
      );
      // Any authenticated user can create notifications (fired by SubmissionChat)
      allow create: if request.auth != null;
      // Mark personal notification read, or admin adds self to readBy on broadcasts
      allow update: if request.auth != null && (
        resource.data.recipientId == request.auth.uid ||
        (resource.data.forAdmins == true && role() == "admin")
      );
    }

    // Admin audit log — admins read/write only
    match /adminAuditLog/{logId} {
      allow read, write: if request.auth != null && role() == "admin";
    }

    // Global config singletons (e.g. the submission cycle counter). Readable
    // by any authenticated user so the submit page can show the current
    // cycle; only admins advance/rewind it.
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && role() == "admin";
    }
  }
}
