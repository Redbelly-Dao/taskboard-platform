rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    // - Anyone authenticated can read their own document
    // - A user can create their own document on registration
    // - Only admins can update other users' roles
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.role == "contributor";
      allow update: if request.auth != null && (
        // Admin can update any user
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        // User can update their own non-role fields
        (request.auth.uid == userId && !("role" in request.resource.data.diff(resource.data).affectedKeys()))
      );
    }

    // Submissions collection
    // - Contributors can create and read their own submissions
    // - Reviewers and admins can read all submissions
    // - Reviewers and admins can update submissions (to add review data)
    match /submissions/{submissionId} {
      allow create: if request.auth != null
        && request.resource.data.contributorId == request.auth.uid
        && request.resource.data.status == "under_review";
      allow read: if request.auth != null && (
        resource.data.contributorId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["reviewer", "admin"]
      );
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["reviewer", "admin"];
    }
  }
}
