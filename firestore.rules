rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the calling user's role
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || role() == "admin"
      );
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == "contributor";
      allow update: if request.auth != null && (
        role() == "admin" ||
        (request.auth.uid == userId && !("role" in request.resource.data.diff(resource.data).affectedKeys()))
      );
    }

    // Tasks collection — readable by all authenticated users; write restricted to admins
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && role() == "admin";
    }

    // Submissions collection
    match /submissions/{submissionId} {
      allow create: if request.auth != null
        && request.resource.data.contributorId == request.auth.uid
        && request.resource.data.status == "under_review";
      allow read: if request.auth != null && (
        resource.data.contributorId == request.auth.uid ||
        role() in ["reviewer", "admin"]
      );
      allow update: if request.auth != null && role() in ["reviewer", "admin"];
    }
  }
}
