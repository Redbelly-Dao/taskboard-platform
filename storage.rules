rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /submissions/{taskId}/{userId}/{fileName} {
      // Only the submitting user can upload their own file
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024; // 50 MB limit
      // Reviewers and admins can read submission files
      allow read: if request.auth != null;
    }
  }
}
